{
  "name": "web",
  "version": "1.0.0",
  "description": "Fuel canister transfer calculator for MSR 110g, 227g, and 450g isobutane cans.",
  "type": "module",
  "scripts": {
    "lint": "node --import tsx ./node_modules/.bin/eslint .",
    "lint:fix": "node --import tsx ./node_modules/.bin/eslint . --fix",
    "typecheck": "tsc --noEmit",
    "bundle": "tsx ./build.mts",
    "bundle:watch": "tsx ./build.mts --watch",
    "build": "npm run lint && npm run typecheck && npm run bundle",
    "build:deploy": "npm run build && tsx ./assemble-site.mts",
    "start": "tsx ./serve.mts",
    "test": "node --test --import tsx solver.test.ts",
    "audit": "npm audit --audit-level=moderate",
    "audit:fix": "npm audit fix"
  },
  "keywords": [
    "msr",
    "isobutane",
    "fuel canister",
    "transfer calculator",
    "backpacking",
    "weight optimization"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.5.0",
    "esbuild": "^0.27.4",
    "eslint": "^10.1.0",
    "postcss": "^8.5.8",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.19.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0"
  }
}
